rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public index collection - read by anyone, write only by Cloud Functions
    match /index/{domain} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Submissions collection - append-only for public, read by anyone
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Crawl queue - internal use only (future feature)
    match /crawl_queue/{id} {
      allow read: if false;
      allow write: if false; // Only Cloud Functions
    }
    
    // Name searches - append-only for public, read by anyone
    match /name_searches/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // User profiles - users can only read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Profiles cannot be deleted via client
      
      // User search history - subcollection
      match /searches/{searchId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false; // History is append-only
      }
      
      // User saved records - subcollection
      match /saved/{recordId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }
    }
    
    // Legacy search history - deprecated, keeping for backward compatibility
    match /searchHistory/{historyId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Alpha Pages - one doc per user, owner can read/write
    match /alphapages/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Alpha pages index - one doc per published page (discovery + machine files). Owner writes on publish.
    match /alpha_pages_index/{pageId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Search log - every search + every file found. Written only by Cloud Functions.
    match /search_log/{logId} {
      allow read: if true;
      allow write: if false;
    }

    // System counters - read by anyone, write by anyone (for global counter)
    match /system/{docId} {
      allow read: if true;
      allow write: if docId == 'aiRecordsCounter'; // Only the AI Records counter is writable
    }
  }
}
