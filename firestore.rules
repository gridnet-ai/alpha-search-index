rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public index collection - read by anyone, write only by Cloud Functions
    match /index/{domain} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Submissions collection - append-only for public, read by anyone
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Crawl queue - internal use only (future feature)
    match /crawl_queue/{id} {
      allow read: if false;
      allow write: if false; // Only Cloud Functions
    }
    
    // Name searches - append-only for public, read by anyone
    match /name_searches/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Search history - users can only read/write their own history
    match /searchHistory/{historyId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // System counters - read by anyone, write by anyone (for global counter)
    match /system/{docId} {
      allow read: if true;
      allow write: if docId == 'aiRecordsCounter'; // Only the AI Records counter is writable
    }
  }
}
